{
  "cli": {
    "version": ">= 3.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "REPLACE_WITH_URL_IN_EAS_OR_ENV",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "REPLACE_WITH_KEY_IN_EAS_OR_ENV",
        "EXPO_PUBLIC_GROQ_API_KEY": "REPLACE_WITH_KEY_IN_EAS_OR_ENV"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
